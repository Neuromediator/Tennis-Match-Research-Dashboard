{
  "permissions": {
    "allow": [
      "Bash(uv sync *)",
      "Bash(uv run *)",
      "Bash(git config *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git submodule *)",
      "Bash(gh repo *)",
      "Bash(gh run *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(uv pip *)",
      "Bash(uv add *)",
      "Bash(tee /tmp/refresh_full.log)",
      "Bash(git rm *)",
      "Bash(git check-ignore *)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false
  }
}
