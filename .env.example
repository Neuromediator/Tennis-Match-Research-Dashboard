# Anthropic API
ANTHROPIC_API_KEY=

# Optional: override the default model
# Recommended values: claude-sonnet-4-6 (default), claude-opus-4-7, claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override data directory (useful for containerized deploys with mounted volumes)
# DATA_DIR=/data

# Optional: override models directory
# MODELS_DIR=/models

# TODO(phase-2): hot tennis API credentials (provider chosen in phase 2)
# TENNIS_API_KEY=
