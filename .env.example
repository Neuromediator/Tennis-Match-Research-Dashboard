# Anthropic API
ANTHROPIC_API_KEY=

# Optional: override the default model
# Recommended values: claude-sonnet-4-6 (default), claude-opus-4-7, claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override data directory (useful for containerized deploys with mounted volumes)
# DATA_DIR=/data

# Optional: override models directory
# MODELS_DIR=/models

# matchstat Tennis API on RapidAPI ("Tennis API - ATP WTA ITF").
# Sign up at https://rapidapi.com, subscribe to the free BASIC plan (500 req/month),
# copy the X-RapidAPI-Key from any endpoint's code snippet or from your default app.
X_RAPIDAPI_KEY=
